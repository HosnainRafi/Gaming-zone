// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
}

enum DeviceStatus {
  AVAILABLE
  RUNNING
  MAINTENANCE
  DISABLED
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_WALLET
  OTHER
}

enum OfferType {
  PERCENT
  FIXED
  TIME_BASED
}

enum MembershipPlanType {
  WEEKLY
  MONTHLY
}

enum SessionPricingType {
  STANDARD
  MEMBERSHIP
  FIRST_TIME_FREE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions       Session[]
  membershipSales MembershipSale[]
  createdOffers  Offer[]   @relation("OfferCreatedBy")
  updatedOffers  Offer[]   @relation("OfferUpdatedBy")

  @@index([role])
}

model Customer {
  id                  String       @id @default(cuid())
  name                String
  phone               String       @unique
  hasClaimedFirstFree Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  memberships         Membership[]
  membershipSales     MembershipSale[]
  sessions            Session[]
}

model MembershipPlan {
  id           String       @id @default(cuid())
  name         String       @unique
  price        Decimal      @db.Decimal(10, 2)
  maxMinutes   Int
  durationDays Int
  isActive     Boolean      @default(true)
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships  Membership[]
  sales        MembershipSale[]

  @@index([isActive, sortOrder])
}

model Membership {
  id               String             @id @default(cuid())
  customerId       String
  planId           String?
  planType         MembershipPlanType?
  planName         String?
  price            Decimal            @db.Decimal(10, 2)
  maxMinutes       Int
  remainingMinutes Int
  startsAt         DateTime           @default(now())
  expiresAt        DateTime
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  customer         Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  plan             MembershipPlan?    @relation(fields: [planId], references: [id], onDelete: SetNull)
  sale             MembershipSale?
  sessions         Session[]

  @@index([customerId, isActive, expiresAt])
  @@index([planType, expiresAt])
  @@index([planId])
}

model MembershipSale {
  id            String          @id @default(cuid())
  membershipId  String          @unique
  customerId    String
  staffId       String
  planId        String?
  planName      String
  amount        Decimal         @db.Decimal(10, 2)
  paymentMethod PaymentMethod   @default(CASH)
  createdAt     DateTime        @default(now())

  membership    Membership      @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  customer      Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staff         User            @relation(fields: [staffId], references: [id], onDelete: Restrict)
  plan          MembershipPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([staffId, createdAt])
  @@index([customerId, createdAt])
  @@index([planId, createdAt])
}

model Device {
  id         String       @id @default(cuid())
  name       String       @unique
  type       String
  hourlyRate Decimal      @db.Decimal(10, 2)
  status     DeviceStatus @default(AVAILABLE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  sessions   Session[]

  @@index([status])
  @@index([type])
}

model Session {
  id              String        @id @default(cuid())
  deviceId        String
  staffId         String
  customerId      String?
  membershipId    String?
  customerName    String?       // customer name for receipt
  customerPhone   String?
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int
  playerCount     Int           @default(1)
  pricingType     SessionPricingType @default(STANDARD)
  baseAmount      Decimal       @default(0) @db.Decimal(10, 2)
  appliedDiscount Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  appliedOfferCode String?
  status          SessionStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  device          Device        @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  staff           User          @relation(fields: [staffId], references: [id], onDelete: Restrict)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  membership      Membership?   @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  transaction     Transaction?

  @@index([deviceId, status])
  @@index([staffId, startTime])
  @@index([status, endTime])
  @@index([customerId, startTime])
  @@index([membershipId])
}

model Transaction {
  id            String        @id @default(cuid())
  receiptNumber Int           @unique @default(autoincrement())
  sessionId     String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  cashPaid      Decimal       @default(0) @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  createdAt     DateTime      @default(now())

  session       Session       @relation(fields: [sessionId], references: [id], onDelete: Restrict)

  @@index([createdAt])
}

model Offer {
  id           String    @id @default(cuid())
  code         String    @unique
  type         OfferType
  value        Decimal   @db.Decimal(10, 2)
  freeMinutes  Int?      // only for TIME_BASED: number of free minutes
  expiry       DateTime
  isActive     Boolean   @default(true)
  createdById  String?
  updatedById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdBy    User?     @relation("OfferCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?     @relation("OfferUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive, expiry])
}
