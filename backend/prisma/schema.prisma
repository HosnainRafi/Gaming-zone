// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STAFF
}

enum DeviceStatus {
  AVAILABLE
  RUNNING
  MAINTENANCE
  DISABLED
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_WALLET
  OTHER
}

enum OfferType {
  PERCENT
  FIXED
  TIME_BASED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions       Session[]
  createdOffers  Offer[]   @relation("OfferCreatedBy")
  updatedOffers  Offer[]   @relation("OfferUpdatedBy")

  @@index([role])
}

model Device {
  id         String       @id @default(cuid())
  name       String       @unique
  type       String
  hourlyRate Decimal      @db.Decimal(10, 2)
  status     DeviceStatus @default(AVAILABLE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  sessions   Session[]

  @@index([status])
  @@index([type])
}

model Session {
  id              String        @id @default(cuid())
  deviceId        String
  staffId         String
  customerName    String?       // customer name for receipt
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int
  totalAmount     Decimal       @db.Decimal(10, 2)
  status          SessionStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  device          Device        @relation(fields: [deviceId], references: [id], onDelete: Restrict)
  staff           User          @relation(fields: [staffId], references: [id], onDelete: Restrict)
  transaction     Transaction?

  @@index([deviceId, status])
  @@index([staffId, startTime])
  @@index([status, endTime])
}

model Transaction {
  id            String        @id @default(cuid())
  receiptNumber Int           @unique @default(autoincrement())
  sessionId     String        @unique
  amount        Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  cashPaid      Decimal       @default(0) @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  createdAt     DateTime      @default(now())

  session       Session       @relation(fields: [sessionId], references: [id], onDelete: Restrict)

  @@index([createdAt])
}

model Offer {
  id           String    @id @default(cuid())
  code         String    @unique
  type         OfferType
  value        Decimal   @db.Decimal(10, 2)
  freeMinutes  Int?      // only for TIME_BASED: number of free minutes
  expiry       DateTime
  isActive     Boolean   @default(true)
  createdById  String?
  updatedById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdBy    User?     @relation("OfferCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?     @relation("OfferUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isActive, expiry])
}
